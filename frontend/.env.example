VITE_APP_NAME=Library System
VITE_API_BASE_URL=/api
VITE_BACKEND_TARGET=http://localhost:8080
VITE_DEV_PORT=5173
VITE_PREVIEW_PORT=4173
VITE_DEFAULT_PAGE_SIZE=10

# Authentication:
# - mock: local demo accounts for UI presentation
# - api: real backend auth integration
VITE_AUTH_MODE=mock
VITE_AUTH_LOGIN_PATH=/auth/login
VITE_AUTH_LOGOUT_PATH=/auth/logout
VITE_AUTH_ME_PATH=/auth/me
VITE_AUTH_USE_CREDENTIALS=false
VITE_AUTH_TOKEN_STORAGE_KEY=library.auth.token
VITE_AUTH_USER_STORAGE_KEY=library.auth.user

# Public browsing:
VITE_ENABLE_PUBLIC_CATALOG=true

# The current Spring Boot backend does not expose this action yet.
# The backend endpoint below is the default contract used by the frontend.
VITE_ENABLE_LOAN_RETURN=true
VITE_LOAN_RETURN_METHOD=post
VITE_LOAN_RETURN_PATH=/loans/:id/return
VITE_LOAN_RETURN_DATE_FIELD=returnDate
