{
    "info": {
        "_postman_id": "2d8d39c3-1cf1-4c28-95cb-0f6d02aee1cf",
        "name": "Library Service Async Scenario",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
        "description": "Коллекция для проверки асинхронного сценария библиотечной системы: создание зависимостей, запуск async-задачи и просмотр статуса. Сначала выполни запросы 1-3 или вручную укажи существующие authorId/categoryId/readerId в переменных коллекции."
    },
    "variable": [
        {
            "key": "baseUrl",
            "value": "http://localhost:8080"
        },
        {
            "key": "authorId",
            "value": "1"
        },
        {
            "key": "categoryId",
            "value": "1"
        },
        {
            "key": "readerId",
            "value": "1"
        },
        {
            "key": "taskId",
            "value": ""
        }
    ],
    "item": [
        {
            "name": "1. Create Author",
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "exec": [
                            "pm.test(\"Status code is 201\", function () {",
                            "    pm.response.to.have.status(201);",
                            "});",
                            "",
                            "var responseJson = pm.response.json();",
                            "pm.collectionVariables.set(\"authorId\", responseJson.id);",
                            "",
                            "pm.test(\"Author id saved\", function () {",
                            "    pm.expect(pm.collectionVariables.get(\"authorId\")).to.exist;",
                            "});"
                        ],
                        "type": "text/javascript"
                    }
                }
            ],
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"firstName\": \"Async\",\n  \"lastName\": \"Author {{$timestamp}}\"\n}"
                },
                "url": {
                    "raw": "{{baseUrl}}/api/authors",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "api",
                        "authors"
                    ]
                },
                "description": "Создаёт автора и сохраняет его id в переменную коллекции {{authorId}}."
            },
            "response": []
        },
        {
            "name": "2. Create Category",
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "exec": [
                            "pm.test(\"Status code is 201\", function () {",
                            "    pm.response.to.have.status(201);",
                            "});",
                            "",
                            "var responseJson = pm.response.json();",
                            "pm.collectionVariables.set(\"categoryId\", responseJson.id);",
                            "",
                            "pm.test(\"Category id saved\", function () {",
                            "    pm.expect(pm.collectionVariables.get(\"categoryId\")).to.exist;",
                            "});"
                        ],
                        "type": "text/javascript"
                    }
                }
            ],
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"name\": \"Async Category {{$timestamp}}\"\n}"
                },
                "url": {
                    "raw": "{{baseUrl}}/api/categories",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "api",
                        "categories"
                    ]
                },
                "description": "Создаёт категорию и сохраняет её id в переменную коллекции {{categoryId}}."
            },
            "response": []
        },
        {
            "name": "3. Create Reader",
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "exec": [
                            "pm.test(\"Status code is 201\", function () {",
                            "    pm.response.to.have.status(201);",
                            "});",
                            "",
                            "var responseJson = pm.response.json();",
                            "pm.collectionVariables.set(\"readerId\", responseJson.id);",
                            "",
                            "pm.test(\"Reader id saved\", function () {",
                            "    pm.expect(pm.collectionVariables.get(\"readerId\")).to.exist;",
                            "});"
                        ],
                        "type": "text/javascript"
                    }
                }
            ],
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"firstName\": \"Async\",\n  \"lastName\": \"Reader {{$timestamp}}\",\n  \"email\": \"reader.{{$timestamp}}@example.com\"\n}"
                },
                "url": {
                    "raw": "{{baseUrl}}/api/readers",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "api",
                        "readers"
                    ]
                },
                "description": "Создаёт читателя и сохраняет его id в переменную коллекции {{readerId}}."
            },
            "response": []
        },
        {
            "name": "4. Start Async Scenario",
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "exec": [
                            "pm.test(\"Status code is 202\", function () {",
                            "    pm.response.to.have.status(202);",
                            "});",
                            "",
                            "var responseJson = pm.response.json();",
                            "pm.collectionVariables.set(\"taskId\", responseJson.taskId);",
                            "",
                            "pm.test(\"Task id saved\", function () {",
                            "    pm.expect(responseJson.taskId).to.exist;",
                            "    pm.expect(responseJson.status).to.be.oneOf([\"PENDING\", \"RUNNING\"]);",
                            "});"
                        ],
                        "type": "text/javascript"
                    }
                }
            ],
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"publisherName\": \"Async Publisher {{$timestamp}}\",\n  \"bookTitle\": \"Async Scenario Book {{$timestamp}}\",\n  \"bookIsbn\": \"ASYNC-{{$timestamp}}-{{$randomInt}}\",\n  \"authorId\": \"{{authorId}}\",\n  \"categoryId\": \"{{categoryId}}\",\n  \"readerId\": \"{{readerId}}\",\n  \"dueDate\": \"2030-12-31\"\n}",
                    "options": {
                        "raw": {
                            "language": "json"
                        }
                    }
                },
                "url": {
                    "raw": "{{baseUrl}}/api/scenarios/with-transaction/async",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "api",
                        "scenarios",
                        "with-transaction",
                        "async"
                    ]
                },
                "description": "Запускает асинхронный сценарий и сохраняет taskId в переменную коллекции {{taskId}}. Перед выполнением бизнес-логики есть задержка 10 секунд, так что сразу после этого шага можно открыть запрос статуса и увидеть runningTasks > 0."
            },
            "response": []
        },
        {
            "name": "5. Get Async Task Status",
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "exec": [
                            "pm.test(\"Status code is 200\", function () {",
                            "    pm.response.to.have.status(200);",
                            "});",
                            "",
                            "var responseJson = pm.response.json();",
                            "",
                            "pm.test(\"Task id matches saved id\", function () {",
                            "    pm.expect(String(responseJson.taskId)).to.eql(String(pm.collectionVariables.get(\"taskId\")));",
                            "});",
                            "",
                            "pm.test(\"Task status is valid\", function () {",
                            "    pm.expect(responseJson.status).to.be.oneOf([\"PENDING\", \"RUNNING\", \"COMPLETED\", \"FAILED\"]);",
                            "});",
                            "",
                            "pm.test(\"Counters are returned\", function () {",
                            "    pm.expect(responseJson.submittedTasks).to.be.a(\"number\");",
                            "    pm.expect(responseJson.runningTasks).to.be.a(\"number\");",
                            "    pm.expect(responseJson.completedTasks).to.be.a(\"number\");",
                            "    pm.expect(responseJson.failedTasks).to.be.a(\"number\");",
                            "});"
                        ],
                        "type": "text/javascript"
                    }
                }
            ],
            "request": {
                "method": "GET",
                "header": [],
                "url": {
                    "raw": "{{baseUrl}}/api/scenarios/tasks/{{taskId}}",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "api",
                        "scenarios",
                        "tasks",
                        "{{taskId}}"
                    ]
                },
                "description": "Возвращает текущий статус async-задачи и значения потокобезопасных счётчиков. Запусти его в течение первых 10 секунд после шага 4, чтобы увидеть статус RUNNING и runningTasks > 0."
            },
            "response": []
        },
        {
            "name": "6. Run Race Condition Demo",
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "exec": [
                            "pm.test(\"Status code is 200\", function () {",
                            "    pm.response.to.have.status(200);",
                            "});",
                            "",
                            "var responseJson = pm.response.json();",
                            "",
                            "pm.test(\"Demo uses 50+ threads\", function () {",
                            "    pm.expect(responseJson.threadCount).to.be.at.least(50);",
                            "});",
                            "",
                            "pm.test(\"Unsafe counter loses updates\", function () {",
                            "    pm.expect(responseJson.unsafeCounterValue).to.be.below(responseJson.expectedValue);",
                            "    pm.expect(responseJson.raceConditionObserved).to.eql(true);",
                            "});",
                            "",
                            "pm.test(\"Safe counters reach expected value\", function () {",
                            "    pm.expect(responseJson.synchronizedCounterValue).to.eql(responseJson.expectedValue);",
                            "    pm.expect(responseJson.atomicCounterValue).to.eql(responseJson.expectedValue);",
                            "});"
                        ],
                        "type": "text/javascript"
                    }
                }
            ],
            "request": {
                "method": "GET",
                "header": [],
                "url": {
                    "raw": "{{baseUrl}}/api/scenarios/race-condition?threadCount=64&incrementsPerThread=1000",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "api",
                        "scenarios",
                        "race-condition"
                    ],
                    "query": [
                        {
                            "key": "threadCount",
                            "value": "64"
                        },
                        {
                            "key": "incrementsPerThread",
                            "value": "1000"
                        }
                    ]
                },
                "description": "Демонстрирует race condition на ExecutorService с 64 потоками и сравнивает unsafe counter с synchronized и AtomicInteger."
            },
            "response": []
        }
    ]
}
